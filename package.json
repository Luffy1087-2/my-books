{
  "name": "my-books",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "@react-oauth/google": "^0.13.4",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^27.5.2",
    "crypto-js": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "tailwindcss": "^4.2.2",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "concurrently \"npm run start:server\" \"vite\"",
    "start:client": "vite",
    "start:server": "node packages/api/dist/index.js",
    "build": "vite build",
    "serve": "vite preview",
    "build:css": "npx @tailwindcss/cli -i src/index.css -o public/index.css --watch",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "build:all": "tsc --build --clean && npm run build --workspaces",
    "docker:build": "docker-compose up -d --build",
    "docker:start": "docker-compose down && docker-compose up -d",
    "docker:stop": "docker-compose down"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/crypto-js": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "fs-extra": "^11.3.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9"
  },
  "workspaces": [
    "packages/api",
    "packages/core"
  ]
}
