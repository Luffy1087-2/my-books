{
  "name": "my-books",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "@react-oauth/google": "^0.13.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^27.5.2",
    "@types/node": "^16.18.126",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "crypto-js": "^4.2.0",
    "jwt-decode": "^4.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-scripts": "5.0.1",
    "typescript": "^4.9.5",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "concurrently \"npm run start:server\" \"npm run start:app\"",
    "start:app": "react-scripts start",
    "start:server": "node packages/api/dist/index.js",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "build:all": "tsc --build --clean && npm run build --workspaces",
    "docker:build": "docker-compose up -d --build",
    "docker:start": "docker-compose down && docker-compose up -d",
    "docker:stop": "docker-compose down"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "concurrently": "^9.2.1"
  },
  "workspaces": [
    "packages/api",
    "packages/core"
  ]
}
