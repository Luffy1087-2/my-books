  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Web App",
      "request": "launch",
      "type": "chrome",
      "url": "https://localhost:3000",
      "webRoot": "${workspaceFolder}"
    },
    {
      "name": "Debug API",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/packages/api/dist/index.js",
      "cwd": "${workspaceFolder}/packages/api"
    }
  ]
}